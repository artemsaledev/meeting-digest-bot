[Unit]
Description=NotebookLM Agent VNC bridge for one-time browser authorization
After=notebooklm-agent-xvfb.service
Requires=notebooklm-agent-xvfb.service

[Service]
Type=simple
User=notebooklm-agent
Group=meetingdigest
EnvironmentFile=-/opt/meeting-digest-bot/data/notebooklm-agent.env
ExecStart=/bin/bash -lc 'exec /usr/bin/x11vnc -display "${NOTEBOOKLM_AGENT_DISPLAY:-:98}" -localhost -forever -shared -noshm -rfbport "${NOTEBOOKLM_AGENT_VNC_PORT:-5905}" -rfbauth /opt/meeting-digest-bot/data/notebooklm-vnc.pass'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
