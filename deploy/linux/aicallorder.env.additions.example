# Add these variables to the AIcallorder .env on the same VPS.
# Use the same MEETING_DIGEST_SHARED_SECRET value as in /opt/meeting-digest-bot/.env.

MEETING_DIGEST_BOT_BASE_URL=http://127.0.0.1:8011
